# Plane MCP Server Configuration

# Plane API Base URL (optional, defaults to https://api.plane.so)
PLANE_BASE_URL=https://api.plane.so

# Plane API Key (REQUIRED for authentication)
# Get this from: https://plane.so/settings/security/api-tokens
PLANE_API_KEY=

# Workspace Slug (optional, defaults to "workspace")
# This is used to identify your Plane workspace
# Example: "acme-corp", "product-team", "testing-workspace"
PLANE_WORKSPACE_SLUG=
